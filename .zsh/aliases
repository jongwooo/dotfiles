alias vim="nvim"

alias t="tmux"
alias tl="tmux list-sessions"
alias tn="tmux new-session"
alias ts="tmux new-session -s"
alias tks="tmux kill-session -t"
alias tkall="tmux kill-server"
function ta() { tmux attach -t "$1" 2>/dev/null || tmux new-session -s "$1"; }
function t3() {
    local name="three_$$"
    tmux new-session -d -s "$name"
    tmux split-window -h -t "$name"
    tmux split-window -h -t "$name"
    tmux select-layout -t "$name" even-horizontal
    tmux attach -t "$name"
}
function t4() {
    local name="four_$$"
    tmux new-session -d -s "$name"
    tmux split-window -t "$name"
    tmux split-window -t "$name"
    tmux split-window -t "$name"
    tmux select-layout -t "$name" tiled
    tmux attach -t "$name"
}
function t6() {
    local name="six_$$"
    tmux new-session -d -s "$name"
    tmux split-window -h -t "$name"
    tmux split-window -h -t "$name"
    tmux select-layout -t "$name" even-horizontal
    tmux select-pane -t "$name":0.0
    tmux split-window -v -t "$name"
    tmux select-pane -t "$name":0.2
    tmux split-window -v -t "$name"
    tmux select-pane -t "$name":0.4
    tmux split-window -v -t "$name"
    tmux attach -t "$name"
}

alias k="kubectl"
alias kdry="kubectl --dry-run=client -o yaml"

alias awspf='export AWS_PROFILE=$(sed -n -E "s/\[(profile )?([^][]+)\]?\s*$/\2/p" ~/.aws/credentials ~/.aws/config | sort -rg | uniq | fzf)'
